<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Not Found — linkr</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/main.css">
</head>
<body>
<%- include('partials/nav') %>
<main class="auth-main">
  <div class="auth-card" style="text-align:center">
    <div style="font-size:3rem;margin-bottom:16px">404</div>
    <h2><% if (username) { %>@<%= username %> not found<% } else { %>Page not found<% } %></h2>
    <p class="auth-sub" style="margin-bottom:24px">This page doesn't exist<% if (!username) { %> or was moved<% } %>.</p>
    <a href="/" class="btn btn-primary">← Back to Home</a>
    <% if (username) { %>
    <p style="margin-top:16px;font-size:0.82rem;color:var(--muted)">
      Want <strong>linkr.me/<%= username %></strong>? <a href="/register">Claim it →</a>
    </p>
    <% } %>
  </div>
</main>
</body>
</html>
