<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard — linkr</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/main.css">
</head>
<body>
<%- include('partials/nav') %>
<main class="dash-main">

  <% if (success) { %>
  <div class="toast-banner">✓ Profile saved successfully!</div>
  <% } %>

  <div class="dash-header">
    <div>
      <h1 class="dash-title">Dashboard</h1>
      <p class="dash-sub">Your profile: <a href="/<%= user.username %>" target="_blank" class="profile-link">linkr.me/<%= user.username %></a></p>
    </div>
    <div class="dash-stats">
      <div class="stat-pill"><span class="stat-num"><%= profile.views %></span><span class="stat-label">Views</span></div>
      <div class="stat-pill"><span class="stat-num"><%= links.length %></span><span class="stat-label">Links</span></div>
    </div>
  </div>

  <div class="dash-grid">

    <!-- LEFT: PREVIEW -->
    <div class="dash-preview">
      <div class="preview-label">Preview</div>
      <div class="profile-card" id="liveCard">
        <div class="profile-banner" id="liveBanner" style="background:<%= profile.banner_color %>"></div>
        <div class="profile-body">
          <div class="profile-avatar" id="liveAvatar">
            <% if (profile.avatar_url) { %>
              <img src="<%= profile.avatar_url %>" alt="avatar">
            <% } else { %>
              <%= (profile.display_name || user.username).charAt(0).toUpperCase() %>
            <% } %>
          </div>
          <div class="profile-name" id="liveName"><%= profile.display_name || user.username %></div>
          <div class="profile-handle">@<%= user.username %></div>
          <div class="profile-bio" id="liveBio"><%= profile.bio || '' %></div>
          <div class="profile-links" id="liveLinks">
            <% links.forEach(link => { %>
            <div class="plink">
              <span class="plink-icon"><%= link.icon %></span>
              <span class="plink-text"><%= link.label %></span>
              <span class="plink-arrow">↗</span>
            </div>
            <% }) %>
          </div>
        </div>
      </div>
    </div>

    <!-- RIGHT: EDITOR -->
    <div class="dash-editor">

      <!-- PROFILE FORM -->
      <div class="editor-section">
        <div class="editor-section-title">✦ Profile Info</div>
        <form action="/dashboard/profile" method="POST" id="profileForm">
          <div class="field-group">
            <label>Display Name</label>
            <input type="text" name="display_name" value="<%= profile.display_name %>" id="inputName" oninput="liveUpdate()" maxlength="40">
          </div>
          <div class="field-group">
            <label>Bio</label>
            <textarea name="bio" id="inputBio" rows="3" oninput="liveUpdate()" maxlength="160"><%= profile.bio %></textarea>
          </div>
          <div class="field-group">
            <label>Banner Color</label>
            <input type="hidden" name="banner_color" id="bannerInput" value="<%= profile.banner_color %>">
            <div class="color-row" id="colorRow">
              <% const banners = [
                'linear-gradient(135deg,#2e1f6b,#6b1f5a,#1f3d6b)',
                'linear-gradient(135deg,#0f2027,#203a43,#2c5364)',
                'linear-gradient(135deg,#1a1a2e,#16213e,#0f3460)',
                'linear-gradient(135deg,#2d1b00,#5c3d00,#8b5a00)',
                'linear-gradient(135deg,#1a2f1a,#0d4a2e,#003d1f)',
                'linear-gradient(135deg,#3d0a0a,#7a1a1a,#4a0000)',
                'linear-gradient(135deg,#1a0533,#3d1166,#6b2fa0)',
                'linear-gradient(135deg,#001233,#023e8a,#0077b6)'
              ]; %>
              <% banners.forEach(b => { %>
                <div class="color-chip <%= profile.banner_color === b ? 'active' : '' %>"
                     style="background:<%= b %>"
                     data-val="<%= b %>"
                     onclick="setBanner(this)"></div>
              <% }) %>
            </div>
          </div>
          <input type="hidden" name="theme" value="dark">
          <button type="submit" class="btn btn-primary btn-full">Save Profile</button>
        </form>
      </div>

      <!-- AVATAR UPLOAD -->
      <div class="editor-section">
        <div class="editor-section-title">🖼 Avatar</div>
        <form action="/dashboard/avatar" method="POST" enctype="multipart/form-data" class="avatar-form">
          <input type="file" name="avatar" accept="image/*" id="avatarFile" onchange="previewAvatar(this)">
          <label for="avatarFile" class="avatar-upload-label">
            <% if (profile.avatar_url) { %>
              <img src="<%= profile.avatar_url %>" class="current-avatar" id="avatarPreview">
            <% } else { %>
              <div class="avatar-placeholder" id="avatarPreview"><%= (profile.display_name||user.username).charAt(0).toUpperCase() %></div>
            <% } %>
            <span>Click to change</span>
          </label>
          <button type="submit" class="btn btn-ghost btn-sm">Upload</button>
        </form>
      </div>

      <!-- LINKS -->
      <div class="editor-section">
        <div class="editor-section-title">🔗 Your Links</div>
        <div class="links-editor" id="linksEditor">
          <% links.forEach(link => { %>
          <div class="link-item" data-id="<%= link.id %>">
            <span class="drag-handle">⠿</span>
            <span class="link-icon-pick"><%= link.icon %></span>
            <div class="link-item-info">
              <span class="link-item-label"><%= link.label %></span>
              <span class="link-item-url"><%= link.url %></span>
            </div>
            <span class="link-clicks"><%= link.clicks %> clicks</span>
            <form action="/dashboard/links/delete" method="POST" style="display:inline">
              <input type="hidden" name="link_id" value="<%= link.id %>">
              <button type="submit" class="btn-del" onclick="return confirm('Delete this link?')">✕</button>
            </form>
          </div>
          <% }) %>
        </div>

        <form action="/dashboard/links/add" method="POST" class="add-link-form">
          <div class="add-link-row">
            <select name="icon" class="icon-select">
              <option value="🔗">🔗</option><option value="🐦">🐦 Twitter</option>
              <option value="📷">📷 Instagram</option><option value="▶️">▶️ YouTube</option>
              <option value="🎵">🎵 TikTok</option><option value="💻">💻 GitHub</option>
              <option value="🎮">🎮 Discord</option><option value="🟣">🟣 Twitch</option>
              <option value="🎧">🎧 Spotify</option><option value="💼">💼 LinkedIn</option>
              <option value="🌐">🌐 Website</option><option value="📧">📧 Email</option>
              <option value="🎨">🎨 Design</option><option value="📱">📱 Other</option>
            </select>
            <input type="text" name="label" placeholder="Label" required maxlength="40">
            <input type="url" name="url" placeholder="https://..." required>
            <button type="submit" class="btn btn-primary btn-sm">Add</button>
          </div>
        </form>
      </div>

    </div>
  </div>
</main>

<script>
function liveUpdate() {
  const name = document.getElementById('inputName').value || 'Your Name';
  const bio = document.getElementById('inputBio').value || '';
  document.getElementById('liveName').textContent = name;
  document.getElementById('liveBio').textContent = bio;
}

function setBanner(el) {
  document.querySelectorAll('.color-chip').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  const val = el.dataset.val;
  document.getElementById('bannerInput').value = val;
  document.getElementById('liveBanner').style.background = val;
}

function previewAvatar(input) {
  if (!input.files || !input.files[0]) return;
  const reader = new FileReader();
  reader.onload = e => {
    const p = document.getElementById('avatarPreview');
    p.outerHTML = '<img src="' + e.target.result + '" class="current-avatar" id="avatarPreview">';
    const liveAv = document.getElementById('liveAvatar');
    liveAv.innerHTML = '<img src="' + e.target.result + '" alt="avatar">';
  };
  reader.readAsDataURL(input.files[0]);
}
</script>
<link rel="stylesheet" href="/css/main.css">
</body>
</html>
