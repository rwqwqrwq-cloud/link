<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= profile.display_name || user.username %> — linkr</title>
<meta name="description" content="<%= profile.bio || '' %>">
<meta property="og:title" content="<%= profile.display_name || user.username %>">
<meta property="og:description" content="<%= profile.bio || '' %>">
<% if (profile.avatar_url) { %><meta property="og:image" content="<%= profile.avatar_url %>"><% } %>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/main.css">
</head>
<body class="profile-page">
<div class="profile-bg" style="background:radial-gradient(ellipse 80% 60% at 30% -10%, rgba(124,111,255,0.15) 0%, transparent 60%), #0a0a0f"></div>

<div class="profile-wrap">
  <div class="profile-card pub">
    <div class="profile-banner" style="background:<%= profile.banner_color %>"></div>
    <div class="profile-body">
      <div class="profile-avatar">
        <% if (profile.avatar_url) { %>
          <img src="<%= profile.avatar_url %>" alt="<%= profile.display_name %>">
        <% } else { %>
          <%= (profile.display_name || user.username).charAt(0).toUpperCase() %>
        <% } %>
      </div>
      <div class="profile-name"><%= profile.display_name || user.username %></div>
      <div class="profile-handle">@<%= user.username %></div>
      <% if (profile.bio) { %>
      <div class="profile-bio"><%= profile.bio %></div>
      <% } %>

      <div class="pub-stats">
        <div class="stat"><span class="stat-num"><%= profile.views.toLocaleString() %></span><span class="stat-label">Views</span></div>
        <div class="stat"><span class="stat-num"><%= links.length %></span><span class="stat-label">Links</span></div>
      </div>

      <div class="profile-links pub-links">
        <% links.forEach(link => { %>
        <a class="plink" href="<%= link.url %>" target="_blank" rel="noopener"
           onclick="trackClick(event, '<%= user.username %>', '<%= link.id %>', '<%= link.url %>')">
          <span class="plink-icon"><%= link.icon %></span>
          <span class="plink-text"><%= link.label %></span>
          <span class="plink-arrow">↗</span>
        </a>
        <% }) %>
        <% if (links.length === 0) { %>
        <p class="no-links">No links yet.</p>
        <% } %>
      </div>
    </div>
  </div>
  <div class="pub-footer">
    <a href="/" class="powered-by">powered by <strong>linkr</strong></a>
  </div>
</div>

<script>
function trackClick(e, username, linkId, url) {
  e.preventDefault();
  fetch('/' + username + '/click/' + linkId, { method: 'POST' })
    .finally(() => window.open(url, '_blank'));
}
</script>
</body>
</html>
