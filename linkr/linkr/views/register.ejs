<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sign up — linkr</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/main.css">
</head>
<body>
<%- include('partials/nav') %>
<main class="auth-main">
  <div class="auth-card">
    <h2>Create your account</h2>
    <p class="auth-sub">Free forever. No credit card required.</p>
    <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
    <form action="/register" method="POST" class="auth-form">
      <div class="field-group">
        <label>Username</label>
        <div class="input-prefix-wrap">
          <span class="input-prefix">linkr.me/</span>
          <input type="text" name="username" placeholder="yourname" required pattern="[a-zA-Z0-9_]{3,24}" maxlength="24" autocomplete="username">
        </div>
        <small>3–24 chars, letters, numbers, underscore</small>
      </div>
      <div class="field-group">
        <label>Email</label>
        <input type="email" name="email" placeholder="you@email.com" required autocomplete="email">
      </div>
      <div class="field-group">
        <label>Password</label>
        <input type="password" name="password" placeholder="Min 6 characters" required minlength="6" autocomplete="new-password">
      </div>
      <button type="submit" class="btn btn-primary btn-full">Create account →</button>
    </form>
    <p class="auth-switch">Already have an account? <a href="/login">Log in</a></p>
  </div>
</main>
</body>
</html>
